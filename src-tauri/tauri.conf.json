{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ToolHub",
  "version": "1.0.6",
  "identifier": "com.toolhub.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "splashscreen",
        "title": "Loading...",
        "url": "splash/index.html",
        "width": 600,
        "height": 400,
        "decorations": false,
        "transparent": false,
        "center": true,
        "resizable": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false
      },
      {
        "label": "main",
        "title": "ToolHub",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "decorations": false,
        "center": true,
        "visible": false
      },
      {
        "label": "floating-ball",
        "title": "AI助手",
        "url": "desktop-floating-ball",
        "width": 60,
        "height": 60,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false
      },
      {
        "label": "sticky-notes",
        "title": "便签",
        "url": "sticky-notes",
        "width": 350,
        "height": 400,
        "minWidth": 300,
        "minHeight": 350,
        "resizable": true,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "center": true,
        "alwaysOnTop": false,
        "skipTaskbar": false,
        "visible": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "**"
        ]
      }
    }
  },
  "plugins": {
    "cli": {
      "description": "Command line interface for the application",
      "args": []
    },
    "updater": {
      "active": false,
      "endpoints": [],
      "dialog": true,
      "pubkey": ""
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "headerImage": "installer/images/installer-header.bmp",
        "sidebarImage": "installer/images/installer-sidebar.bmp",
        "installerIcon": "icons/icon.ico",
        "installMode": "perMachine",
        "languages": [
          "SimpChinese",
          "English"
        ],
        "displayLanguageSelector": true
      },
      "wix": {
        "language": [
          "zh-CN",
          "en-US"
        ],
        "template": null
      }
    },
    "resources": {
      "binaries/aria2c.exe": "binaries/aria2c.exe"
    },
    "publisher": "ToolHub Team",
    "copyright": "Copyright © 2026",
    "category": "Utility",
    "shortDescription": "All-in-one productivity toolbox for modern workflow",
    "longDescription": "ToolHub is a modern desktop application that integrates document management, AI assistants, task management and more utilities to boost your productivity."
  }
}
